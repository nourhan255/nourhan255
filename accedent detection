        "def sample_frames(video_path, sample_every_sec=1):\n",
        "    cap = cv2.VideoCapture(video_path)\n",
        "    fps = int(cap.get(cv2.CAP_PROP_FPS))\n",
        "\n",
        "    frames = []\n",
        "    frame_id = 0\n",
        "\n",
        "    while True:\n",
        "        ret, frame = cap.read()\n",
        "        if not ret:\n",
        "            break\n",
        "\n",
        "        if frame_id % (fps * sample_every_sec) == 0:\n",
        "            frames.append(frame)\n",
        "\n",
        "        frame_id += 1\n",
        "\n",
        "    cap.release()\n",
        "    return frames, fps\n",
        "\n",
        "\n",
        "for video in videos:\n",
        "    frames, fps = sample_frames(video, 1)\n",
        "\n",
        "\n",
        "\n",
